# ============================================================
# .env.example — Variabel environment frontend SDENTIBAYA AdminKit
#
# CARA PAKAI:
#   1. Salin file ini: cp .env.example .env.local
#   2. Isi VITE_API_URL dengan URL Cloudflare Worker Anda
#   3. JANGAN commit .env.local ke git
# ============================================================

# URL Cloudflare Worker
# Development (wrangler dev) : http://localhost:8787
# Production                 : https://<nama-worker>.<akun>.workers.dev
#
# Jika TIDAK diset → aplikasi berjalan dalam MODE DEMO
# (semua data adalah dummy, login PIN: 123456)
VITE_API_URL=http://localhost:8787
